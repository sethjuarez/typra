{
  "name": "typra",
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "devDependencies": {
    "@typespec/compiler": "1.10.0",
    "@typespec/json-schema": "1.10.0"
  },
  "overrides": {
    "@typespec/compiler": "1.10.0",
    "@typespec/json-schema": "1.10.0"
  },
  "scripts": {
    "build": "npm run build --workspace @typra/emitter",
    "test": "npm run test --workspace @typra/emitter",
    "generate:fixtures": "npm run generate:fixtures --workspace @typra/emitter",
    "validate:fixtures": "npm run validate:fixtures --workspace @typra/emitter",
    "pack:dry-run": "npm pack --workspace @typra/emitter --dry-run"
  },
  "packageManager": "npm@11.5.1"
}
